# Server
PORT=5000
NODE_ENV=development

# MongoDB (use your connection string)
MONGODB_URI=mongodb://localhost:27017/amu_web

# CORS - Frontend URLs (comma-separated for multiple)
# Dev: http://localhost:5173
# Prod: https://euphonious-kheer-5db008.netlify.app
CORS_ORIGINS=http://localhost:5173,https://euphonious-kheer-5db008.netlify.app

# JWT Secret for admin auth (change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# API base URL (for upload URLs and fixing localhost photo refs in production)
API_BASE_URL=https://api.etihadamu.com

# Admin credentials (used by seed)
ADMIN_EMAIL=admin@amu.one
ADMIN_PASSWORD=Admin@123
